{
    "name": "appin/appin-chat",
    "description": "AI chat widget for WordPress, powered by AppIn",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "laravel/pint": "^1.18",
        "phpstan/phpstan": "^1.12",
        "szepeviktor/phpstan-wordpress": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "AppInIo\\Chat\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AppInIo\\Chat\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "test:filter": "phpunit --filter",
        "lint": "pint --test",
        "lint:fix": "pint",
        "analyse": "phpstan analyse --no-progress --memory-limit=512M",
        "ci": [
            "@lint",
            "@analyse",
            "@test"
        ]
    }
}
