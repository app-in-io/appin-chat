msgid "Appinio Chat"
msgstr "Appinio Chat"

msgid "Add an AI chat widget to your WordPress site. Powered by Appinio."
msgstr "Lisa WordPressi saidile AI-vestlusevidin. Rakendab Appinio."

msgid "Appinio"
msgstr "Appinio"

msgid "Remove"
msgstr "Eemalda"

msgid "Connection"
msgstr "Ühendus"

msgid "Connect your site to the Appinio chat widget."
msgstr "Ühenda sait Appinio-i vestlusevidinaga."

msgid "Site ID"
msgstr "Saidi ID"

msgid "Web Channel ID from the Appinio dashboard. Required for the widget to work."
msgstr "Web Channel ID Appinio-i töölaualt. Vidina toimimiseks kohustuslik."

msgid "Appearance"
msgstr "Välimus"

msgid "Customize the look and feel of the chat widget."
msgstr "Kohanda vestlusevidina välimust ja käitumist."

msgid "Title"
msgstr "Pealkiri"

msgid "Chat header title. Defaults to \"AI Assistant\"."
msgstr "Vestluse päise pealkiri. Vaikimisi „AI Assistant“."

msgid "Subtitle"
msgstr "Alapealkiri"

msgid "Chat header subtitle. Leave empty to hide."
msgstr "Vestluse päise alapealkiri. Peitmiseks jäta tühjaks."

msgid "Logo"
msgstr "Logo"

msgid "Image displayed in the chat header."
msgstr "Vestluse päises kuvatav pilt."

msgid "Theme"
msgstr "Teema"

msgid "Light"
msgstr "Hele"

msgid "Dark"
msgstr "Tume"

msgid "Position"
msgstr "Asukoht"

msgid "Bottom Right"
msgstr "All paremal"

msgid "Bottom Left"
msgstr "All vasakul"

msgid "Language"
msgstr "Keel"

msgid "Fallback language code (e.g. en, de, fr). Auto-detected from Polylang/WPML when active."
msgstr "Varukeelekood (nt en, de, fr). Tuvastatakse automaatselt Polylangist/WPMList, kui need on aktiivsed."

msgid "Accent Color"
msgstr "Rõhuvärv"

msgid "Primary accent color for buttons and highlights."
msgstr "Nuppude ja esiletõstude peamine rõhuvärv."

msgid "Price Prefix"
msgstr "Hinnaeesliide"

msgid "Prefix for price display in product cards (e.g. \"from\")."
msgstr "Hinnaeesliide tootekaartidel (nt „alates“)."

msgid "Custom Colors"
msgstr "Kohandatud värvid"

msgid "Override individual CSS color variables. Leave empty to use defaults."
msgstr "Kirjuta üle üksikud CSS-i värvimuutujad. Vaikeväärtuste kasutamiseks jäta tühjaks."

msgid "Primary"
msgstr "Peamine"

msgid "Surface"
msgstr "Pind"

msgid "Surface Alt"
msgstr "Pind (alternatiiv)"

msgid "Text"
msgstr "Tekst"

msgid "Text Muted"
msgstr "Tuhm tekst"

msgid "Border"
msgstr "Äärejoon"

msgid "User Message BG"
msgstr "Kasutaja sõnumi taust"

msgid "Assistant Message BG"
msgstr "Assistendi sõnumi taust"

msgid "Body Font"
msgstr "Põhiteksti kirjatüüp"

msgid "CSS font-family for body text (e.g. Inter, system-ui, sans-serif)."
msgstr "Põhiteksti CSS font-family (nt Inter, system-ui, sans-serif)."

msgid "Heading Font"
msgstr "Pealkirja kirjatüüp"

msgid "CSS font-family for headings (e.g. Space Grotesk, system-ui, sans-serif)."
msgstr "Pealkirjade CSS font-family (nt Space Grotesk, system-ui, sans-serif)."

msgid "Select Image"
msgstr "Vali pilt"

msgid "Behavior"
msgstr "Käitumine"

msgid "Control how the chat window behaves after the page loads."
msgstr "Määrake, kuidas vestlusaken pärast lehe laadimist käitub."

msgid "Auto-open"
msgstr "Automaatne avamine"

msgid "Never"
msgstr "Mitte kunagi"

msgid "Once per session"
msgstr "Üks kord seansi kohta"

msgid "Every page load"
msgstr "Iga lehe laadimisel"

msgid "Auto-open Delay (seconds)"
msgstr "Automaatse avamise viivitus (sekundites)"

msgid "Seconds to wait after page load before auto-opening. Used only when Auto-open is enabled."
msgstr "Sekundid, mille võrra pärast lehe laadimist enne automaatset avamist oodatakse. Kasutatakse ainult siis, kui automaatne avamine on lubatud."
